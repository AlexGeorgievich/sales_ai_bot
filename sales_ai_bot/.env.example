# API Keys
GIGACHAT_API_KEY=<твой код>
PROXY_API_KEY=your_proxy_key_here

# Database
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sales_bot
# REDIS_URL=redis://localhost:6379/0

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
