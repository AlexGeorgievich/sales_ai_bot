# App Settings
PROJECT_NAME=Sales AI Bot MVP
DEBUG=true
MAX_CONCURRENT_SESSIONS=1000
RESPONSE_TIMEOUT=2

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

